# ============================================================
# 电商智能客服系统 — 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ── DashScope LLM / Embedding ──────────────────────────────
DASHSCOPE_API_KEY=your_api_key_here
LLM_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v3

# ── PostgreSQL ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=ecommerce_cs

# ── LangSmith（可选，用于评估和追踪）──────────────────────
LANGCHAIN_API_KEY=your_langsmith_key
LANGCHAIN_PROJECT=ecommerce_cs
LANGCHAIN_TRACING_V2=false

# ── MCP: 物流查询（可选）───────────────────────────────────
KUAIDI100_KEY=your_kuaidi100_api_key
KUAIDI100_SECRET=your_kuaidi100_secret

# ── MCP: 支付服务（可选）───────────────────────────────────
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
WECHATPAY_MCH_ID=your_wechatpay_merchant_id
WECHATPAY_API_KEY=your_wechatpay_api_key

# ── MCP: 通知服务（可选）───────────────────────────────────
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your_smtp_password

# ── MCP: 库存管理（可选）───────────────────────────────────
ERP_API_URL=https://erp.example.com/api
ERP_API_KEY=your_erp_api_key
